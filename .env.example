GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_ENABLED=true

# Local retrieval remains the highest priority. Gemini is called only below this score.
MIN_RETRIEVAL_SCORE=0.45

# Optional local model override. Use base model only before fine-tune.
EMBEDDING_MODEL_NAME=data/models/vietnamese-embedding-legal

# Chat history/cache. Stored under data/ so it survives container restart.
CHAT_DB_PATH=data/chat_history.sqlite3

# Daily watchlist report email.
# Scheduler runs inside backend and sends reports at REPORT_DAILY_TIME every day.
REPORT_SCHEDULER_ENABLED=false
REPORT_DAILY_TIME=07:00
REPORT_TIMEZONE=Asia/Ho_Chi_Minh
REPORTS_DIR=data/reports
REPORT_WATCHLIST_TOPICS=cập nhật thông tin căn cước,cải chính hộ tịch,đăng ký doanh nghiệp,cấp giấy chứng nhận quyền sử dụng đất,thay đổi thông tin đăng ký thuế

# SMTP delivery. Example: Gmail app password, SendGrid SMTP, or internal SMTP relay.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_EMAIL=chatbot-law-vn@example.com
SMTP_USE_TLS=true
