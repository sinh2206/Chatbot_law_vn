# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Data / Vector DB
DATA_DIR=Multi-Agent
VECTOR_STORE_DIR=vector_store
COLLECTION_NAME=legal_docs

# Metadata / logs
METADATA_DIR=metadata
LEGAL_METADATA_FILE=metadata/legal_documents_metadata.csv
LOGS_DIR=logs
ADMIN_ALERT_LOG_FILE=logs/admin_alerts.log

# Frontend static
FRONTEND_DIR=frontend
DASHBOARD_DIR=dashboard
TESTSUITE_DIR=testsuite
TELEMETRY_DB_FILE=logs/telemetry.db
REPORTS_DIR=reports

# Chunking
CHUNK_SIZE=900
CHUNK_OVERLAP=150
TOP_K=5
MAX_CONTEXT_CHUNKS=5

# Embedding
# Options: gemini | sentence-transformers
EMBEDDING_BACKEND=gemini
EMBEDDING_MODEL=models/embedding-001
SENTENCE_TRANSFORMER_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2

# LLM
LLM_MODEL=gemini-2.5-flash-lite
LLM_TEMPERATURE=0.1
INTENT_TEMPERATURE=0.0
MERGE_TEMPERATURE=0.1
LLM_MAX_OUTPUT_TOKENS=1024

# Expiry scan
EXPIRY_SCAN_INTERVAL_HOURS=24

# Web fallback
WEB_FALLBACK_ENABLED=true
WEB_SEARCH_BACKEND=ddgs
WEB_SEARCH_MAX_RESULTS=8
TRUSTED_WEB_DOMAINS=chinhphu.vn,congbao.chinhphu.vn,vbpl.vn,thuvienphapluat.vn,moj.gov.vn

# Admin notification
ADMIN_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SENDER=
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# CORS
CORS_ALLOW_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:8000,http://127.0.0.1:8000,http://localhost:8501,http://127.0.0.1:8501

# Dashboard alerts
ALERT_MIN_ACCURACY=75
ALERT_MAX_AVG_RESPONSE_MS=12000
ALERT_MAX_FALLBACK_RATE=0.35

# Test suite
TEST_DATASET_FILE=testsuite/test_cases.json
TEST_PASS_SCORE=6.0
TEST_USE_LLM_GRADER=false
TEST_RUNNER_MODE=api
TEST_API_BASE_URL=http://localhost:8000
TEST_API_TIMEOUT_SECONDS=180
TEST_ALLOW_DIRECT_FALLBACK=true
TEST_REPORT_SEND_EMAIL=false
