GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_ENABLED=true

# Local retrieval remains the highest priority. Gemini is called only below this score.
MIN_RETRIEVAL_SCORE=0.45

# Optional local model override. Use base model only before fine-tune.
EMBEDDING_MODEL_NAME=data/models/vietnamese-embedding-legal

# Chat history/cache. Stored under data/ so it survives container restart.
CHAT_DB_PATH=data/chat_history.sqlite3
